// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN  
  USER
  COMPANY
}


enum RoomType {
  USER
  MARKETPLACE
  DONATION
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

model User {
  id        String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String?
  profilePicture String?
  
  // Location
  address        String?
  latitude       Float?
  longitude      Float?
  
  role           Role     @default(USER)
  phone          String?
  
  // Status
  is_active Boolean @default(false)
  is_verified Boolean @default(false)
  login_attempt Int @default(0)
  last_login DateTime?
  refreshToken String? @unique
  
  // Relation
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Chat
  rooms     RoomUser[]
  messages  Message[]

  // Community
  communityPosts CommunityPost[]
  communityComments Comment[]

  // Donation
  donations      Donation[]
  points         Int      @default(0)
  marketplaceOrders MarketplaceOrder[]
  cartItems      CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
}

model Company {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  email     String?
  website   String?
  logo      String?
  description String?
  
  // Relation
  users     User[]
  donations Donation[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
}

model ChatRoom {
  id            String      @id @default(uuid())
  type          RoomType

  users         RoomUser[]
  messages      Message[]

  lastMessage   String?
  lastMessageAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
}

model RoomUser {
  id      String   @id @default(uuid())

  userId  String
  roomId  String

  user    User     @relation(fields: [userId], references: [id])
  room    ChatRoom @relation(fields: [roomId], references: [id])

  @@unique([userId, roomId]) // biar ga dobel join

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
}

model Message {
  id        String   @id @default(uuid())

  roomId    String
  userId    String

  content   String
  imageUrl  String?
  type      MessageType @default(TEXT)
  isRead    Boolean     @default(false)

  createdAt DateTime @default(now())

  room      ChatRoom @relation(fields: [roomId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
}

model CommunityPost {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  type      PostType @default(EDUCATION)
  
  // Geolocation
  latitude  Float?
  longitude Float?
  address   String?
  images    PostImage[]
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  
  comments  Comment[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model PostImage {
  id        String   @id @default(uuid())
  url       String
  
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
}

model Donation {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  
  type        DonationType
  companyId   String?       // if type is COMPANY
  company     Company?      @relation(fields: [companyId], references: [id])
  
  description String?
  grade       DonationGrade
  points      Int           @default(0)
  images      DonationImage[]
  status      DonationStatus
  createdAt   DateTime      @default(now())
  updatedAt   DateTime?     @updatedAt
  deletedAt   DateTime?
}

model DonationImage {
  id          String   @id @default(uuid())
  url         String
  
  donationId  String
  donation    Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime? @updatedAt
  deletedAt   DateTime?
}

model MarketplaceItem {
  id          String   @id @default(uuid())
  name        String
  description String   @db.Text
  price       Int
  stock       Int      @default(0)
  category    String?
  points      Int      @default(0) // points awarded upon purchase
  
  images      MarketplaceItemImage[]
  orderItems  MarketplaceOrderItem[]
  cartItems   CartItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model MarketplaceItemImage {
  id      String @id @default(uuid())
  url     String
  itemId  String
  item    MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  itemId    String
  item      MarketplaceItem @relation(fields: [itemId], references: [id])
  
  quantity  Int      @default(1)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, itemId])
}

model MarketplaceOrder {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  items           MarketplaceOrderItem[]
  
  totalPrice      Int
  paymentProof    String?  // Screenshot of payment
  status          MarketplaceOrderStatus @default(PENDING)
  totalPointsAwarded Int      @default(0)
  
  // Shipping Data
  recipientName   String?
  phone           String?
  address         String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
}

model MarketplaceOrderItem {
  id              String   @id @default(uuid())
  orderId         String
  order           MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  itemId          String
  item            MarketplaceItem @relation(fields: [itemId], references: [id])
  
  quantity        Int      @default(1)
  priceAtPurchase Int
  pointsAtPurchase Int
  
  createdAt       DateTime @default(now())
}

enum MarketplaceOrderStatus {
  PENDING
  VERIFYING
  VERIFIED
  REJECTED
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PostType {
  EDUCATION
  EXCHANGE
  ANNOUNCEMENT
}

enum DonationGrade {
  LAYAK
  TIDAK_LAYAK
  BISA_DIPERBAIKI
}

enum DonationType {
  COMPANY
  AMERTA
}

enum DonationStatus {
  PENDING
  COMPLETED
  CANCELLED
  ONGOING
} 
