// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN  
  USER
  COMPANY
}


enum RoomType {
  USER
  MARKETPLACE
  DONATION
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  phone     String?
  address   String?

  // Lokasi
  longitude Float?
  latitude  Float?
  
  // Status
  is_verified Boolean @default(false)
  login_attempt Int @default(0)
  last_login DateTime?
  
  // Relation
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Chat
  rooms     RoomUser[]
  messages  Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
}

model Company {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  email     String?
  website   String?
  logo      String?
  description String?
  
  // Relation
  users     User[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
}

model ChatRoom {
  id            String      @id @default(uuid())
  type          RoomType
    createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?

  users         RoomUser[]
  messages      Message[]

  lastMessage   String?
  lastMessageAt DateTime?


}

model RoomUser {
  id      String   @id @default(uuid())

  userId  String
  roomId  String

  user    User     @relation(fields: [userId], references: [id])
  room    ChatRoom @relation(fields: [roomId], references: [id])

  @@unique([userId, roomId]) // biar ga dobel join

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
}

model Message {
  id        String   @id @default(uuid())

  roomId    String
  userId    String

  content   String
  imageUrl  String?
  type      MessageType @default(TEXT)
  isRead    Boolean     @default(false)

  createdAt DateTime @default(now())

  room      ChatRoom @relation(fields: [roomId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
}
